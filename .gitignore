scripts/tsmis_auth.json

# Local Claude Code permission state (not app code).
.claude/

# output/ holds generated files (potentially gigabytes). Keep the folder
# structure committed via .gitkeep stubs, but ignore everything else so
# exports and consolidated workbooks don't accidentally get checked in.
output/*
!output/ramp_summary/
!output/ramp_detail/
!output/highway_sequence/
!output/highway_log/
!output/highway_log_pdf/
!output/intersection_summary/
!output/intersection_detail/
!output/consolidated/
output/ramp_summary/*
output/ramp_detail/*
output/highway_sequence/*
output/highway_log/*
output/highway_log_pdf/*
output/intersection_summary/*
output/intersection_detail/*
output/consolidated/*
!output/ramp_summary/.gitkeep
!output/ramp_detail/.gitkeep
!output/highway_sequence/.gitkeep
!output/highway_log/.gitkeep
!output/highway_log_pdf/.gitkeep
!output/intersection_summary/.gitkeep
!output/intersection_detail/.gitkeep
!output/consolidated/.gitkeep

# input/ holds user-supplied source files (TSN district PDFs — these come from
# outside the app). Keep the folder structure via .gitkeep, ignore the files
# themselves. (The TSMIS Highway Log PDFs are this app's OWN export now, read from
# output/<run>/highway_log_pdf/, so there is no input folder for them.)
input/*
!input/tsn_highway_log/
input/tsn_highway_log/*
!input/tsn_highway_log/.gitkeep

__pycache__/
*.pyc
.venv/

# Build artifacts (portable onefolder packaging). Keep build\app.spec, build.ps1,
# build\prune_bundle.ps1 and build\full_smoke.py tracked; ignore the heavy
# generated pieces. (build\ms-playwright\ is a defensive no-op now -- no browser
# is bundled -- but stays ignored in case a browser is ever bundled again.)
/dist/
build/ms-playwright/
build/pyi-work/
/TSMIS-Exporter-*.zip          # the distributable zip (uploaded to GitHub Releases)

# Phase 1 packaging spike (throwaway -- superseded by build/)
spike/

# Runtime diagnostics written next to the app (dev: repo root). The rotating
# log and per-failure screenshots/HTML are local artifacts, never committed.
/logs/
/failures/
/edge_login_profile/
/data/edge_login_profile/
/webview2/
/data/webview2/

# Built-in Chromium downloaded from the Settings tab (paths.DOWNLOADED_BROWSERS_DIR;
# dev: repo root, packaged app: data\ms-playwright). Never committed.
/ms-playwright/
/data/ms-playwright/

# Persisted user settings (timeouts, URL overrides — local state, never committed)
/config.json
/data/config.json

# Export-Everything batch manifest (B3; paths.DATA_ROOT/batch_job.json — dev:
# repo root, packaged app: data\batch_job.json). Local run state, never committed.
/batch_job.json
/data/batch_job.json

# Canonical TSN library (paths.TSN_LIBRARY_ROOT; dev: repo root, packaged app:
# data\tsn_library). Holds the user's REAL TSN source + consolidated files,
# which are LOCAL ONLY (Caltrans-internal) and must NEVER be committed. The
# packaged data\ location is covered by the blanket /data/ rule below; this is
# the dev-root one. (ensure_layout() seeds folders/hints here on app start.)
/tsn_library/

# The packaged app's data dir (profiles, caches, settings, manifests, downloaded
# browser). All current contents are ignored individually above; this blanket
# rule is defense-in-depth so a future data\ file can't be committed by accident.
/data/

# Local scratch area for code-review audit runs. The reusable prompt is the
# tracked docs/code-review-prompt.md; per-run reports quote code +
# internal detail, so they stay local (never committed).
/code-review/
