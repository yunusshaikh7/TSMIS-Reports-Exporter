scripts/tsmis_auth.json

# Local Claude Code permission state (not app code).
.claude/

# output/ holds generated files (potentially gigabytes). Keep the folder
# structure committed via .gitkeep stubs, but ignore everything else so
# exports and consolidated workbooks don't accidentally get checked in.
output/*
!output/ramp_summary/
!output/ramp_detail/
!output/highway_sequence/
!output/highway_log/
!output/consolidated/
output/ramp_summary/*
output/ramp_detail/*
output/highway_sequence/*
output/highway_log/*
output/consolidated/*
!output/ramp_summary/.gitkeep
!output/ramp_detail/.gitkeep
!output/highway_sequence/.gitkeep
!output/highway_log/.gitkeep
!output/consolidated/.gitkeep

# input/ holds user-supplied source files (TSN district PDFs). Keep the folder
# structure via .gitkeep, ignore the files themselves.
input/*
!input/tsn_highway_log/
input/tsn_highway_log/*
!input/tsn_highway_log/.gitkeep

__pycache__/
*.pyc
.venv/

# Build artifacts (portable onefolder packaging). Keep build\app.spec, build.ps1,
# build\prune_bundle.ps1 and build\full_smoke.py tracked; ignore the heavy
# generated pieces. (build\ms-playwright\ is a defensive no-op now -- no browser
# is bundled -- but stays ignored in case a browser is ever bundled again.)
/dist/
build/ms-playwright/
build/pyi-work/
/TSMIS-Exporter-*.zip          # the distributable zip (uploaded to GitHub Releases)

# Phase 1 packaging spike (throwaway -- superseded by build/)
spike/

# Runtime diagnostics written next to the app (dev: repo root). The rotating
# log and per-failure screenshots/HTML are local artifacts, never committed.
/logs/
/failures/
/edge_login_profile/
/data/edge_login_profile/
/webview2/
/data/webview2/

# Built-in Chromium downloaded from the Settings tab (paths.DOWNLOADED_BROWSERS_DIR;
# dev: repo root, packaged app: data\ms-playwright). Never committed.
/ms-playwright/
/data/ms-playwright/

# Persisted user settings (timeouts, URL overrides — local state, never committed)
/config.json
/data/config.json
