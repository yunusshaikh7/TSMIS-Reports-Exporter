scripts/tsmis_auth.json

# output/ holds generated files (potentially gigabytes). Keep the folder
# structure committed via .gitkeep stubs, but ignore everything else so
# exports and consolidated workbooks don't accidentally get checked in.
output/*
!output/ramp_summary/
!output/ramp_detail/
!output/highway_sequence/
!output/consolidated/
output/ramp_summary/*
output/ramp_detail/*
output/highway_sequence/*
output/consolidated/*
!output/ramp_summary/.gitkeep
!output/ramp_detail/.gitkeep
!output/highway_sequence/.gitkeep
!output/consolidated/.gitkeep

__pycache__/
*.pyc
.venv/

# Build artifacts (portable onefolder packaging). Keep build\*.spec, build.ps1
# and build\smoke_entry.py tracked; ignore the heavy generated pieces.
/dist/
build/ms-playwright/
build/pyi-work/

# Phase 1 packaging spike (throwaway -- superseded by build/)
spike/

# Runtime diagnostics written next to the app (dev: repo root). The rotating
# log and per-failure screenshots/HTML are local artifacts, never committed.
/logs/
/failures/
